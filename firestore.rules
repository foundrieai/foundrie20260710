rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Email comparison is case-sensitive in rules, but providers return the
      // address in canonical (lowercase) form — so compare lowercase-to-lowercase.
      return request.auth != null && (
        request.auth.token.admin == true ||
        (request.auth.token.email != null &&
          request.auth.token.email.lower() in [
            'hello@thesiliconhill.com',
            'hello@foundrieai.com',
            'robertkwilliams.dc@gmail.com'
          ])
      );
    }

    // Read-only investor/mentor access. The owner adds a viewer by email; a doc
    // keyed by that lowercased email under users/{userId}/viewers grants the
    // holder READ access to the owner's LaunchCode files. Never grants write.
    function isViewer(userId) {
      return request.auth != null && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/users/$(userId)/viewers/$(request.auth.token.email));
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if (request.auth != null && (request.auth.uid == userId || isAdmin())) || isViewer(userId);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Owner/admin manage the viewer allow-list; viewers never read this list.
    match /users/{userId}/viewers/{viewerEmail} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/journey/{document=**} {
      allow read:  if (request.auth != null && (request.auth.uid == userId || isAdmin())) || isViewer(userId);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/evidence/{evidenceId} {
      allow read:  if (request.auth != null && (request.auth.uid == userId || isAdmin())) || isViewer(userId);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/decisions/{decisionId} {
      allow read:  if (request.auth != null && (request.auth.uid == userId || isAdmin())) || isViewer(userId);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/reports/{reportId} {
      // Owner and admins always read; invited viewers read; everyone else only
      // if the owner enabled an unlisted link (isShared == true).
      allow read: if (request.auth != null && (request.auth.uid == userId || isAdmin()))
                  || isViewer(userId)
                  || resource.data.isShared == true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null;
    }

    // Resumait resumes are NOT part of the LaunchCode share — owner/admin only.
    match /users/{userId}/resumes/{resumeId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/reports/{reportId}/messages/{messageId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /promotedReports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Public contact form submissions. Anyone may submit; only admins may read.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Help Desk reports / support tickets. Anyone may submit; only admins may read.
    match /supportTickets/{ticketId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Inquiries sent to a founder about a promoted idea. Anyone may send; the
    // idea's owner (or an admin) may read them.
    match /ideaInquiries/{inquiryId} {
      allow create: if true;
      allow read: if request.auth != null && (request.auth.uid == resource.data.ownerUserId || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
